# LM Studio Configuration Examples
# Copy this file to .env and modify as needed

# Qwen2.5 7B Instruct Configuration
LLM_AGENT_BACKEND=lmstudio
LLM_AGENT_ENDPOINT=http://localhost:1234/v1/chat/completions
LLM_AGENT_MODEL=qwen2.5-7b-instruct-q4_k_m.gguf
LLM_AGENT_TIMEOUT_S=60
LLM_AGENT_USE_VISION=0

# Deepseek Coder 6.7B Configuration  
# LLM_AGENT_BACKEND=lmstudio
# LLM_AGENT_ENDPOINT=http://localhost:1234/v1/chat/completions
# LLM_AGENT_MODEL=deepseek-coder-6.7b-base-q4_k_m.gguf
# LLM_AGENT_TIMEOUT_S=60
# LLM_AGENT_USE_VISION=0

# Generic LM Studio (uses whatever model is loaded)
# LLM_AGENT_BACKEND=lmstudio
# LLM_AGENT_ENDPOINT=http://localhost:1234/v1/chat/completions
# LLM_AGENT_MODEL=local-model
# LLM_AGENT_TIMEOUT_S=60
# LLM_AGENT_USE_VISION=1
